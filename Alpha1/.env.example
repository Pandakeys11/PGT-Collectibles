# Auth: Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# ngrok (local Clerk webhooks): https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/liquid-scan
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/liquid-scan
# Legacy `/scanner` URL: default redirects to /liquid-scan. Set LEGACY_SCANNER_ENABLED=0 for HTTP 410.
LEGACY_SCANNER_ENABLED=1

# Database: Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Billing (Stripe) — standard Checkout only, NOT Stripe Connect
# Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: Developers → Webhooks → Add endpoint (NOT Connect webhooks)
#   URL: https://your-domain.com/api/billing/webhook
#   Event: checkout.session.completed
#   Docs: https://docs.stripe.com/webhooks (not /connect/webhooks)
# Local: stripe listen --forward-to localhost:3002/api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Public app URL for checkout redirects (defaults to VERCEL_URL or http://localhost:3002)
NEXT_PUBLIC_APP_URL=

# Vision providers (configure at least one; benchmark: npm run vision:benchmark)
GROQ_API_KEY=
GEMINI_API_KEY=
# GEMINI_DISABLED=1
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# xAI / Grok (vision + optional paid tier; requires console credits)
XAI_API_KEY=
XAI_VISION_MODEL=grok-4-1-fast-non-reasoning
# XAI_BASE_URL=https://api.x.ai/v1

GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_VISION_VERIFY_MODEL=gemini-2.5-flash
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENAI_VISION_MODEL=gpt-4o-mini

# Free-tier-only mode: auto-skips OpenAI/xAI even if keys exist (recommended with paid Groq).
FREE_TIER_ONLY=1

# Paid Groq testing — Groq-only vision + text (no OpenRouter/Gemini fallback = no double spend).
# GROQ_PRIMARY_ONLY=1
# Production accuracy: leave GROQ_PRIMARY_ONLY unset and do not skip providers.
# Example (Gemini quota exhausted):
# VISION_PROVIDER_ORDER=openrouter,groq
# VISION_SKIP_PROVIDERS=gemini
# GEMINI_DISABLED=1
# LIQUID_ASK_GEMINI_RESEARCH=0
# SCAN_AUTO_REPORT=1
# NEXT_PUBLIC_SCAN_AUTO_REPORT=1
# GROQ_TEXT_MAX_TOKENS_ASK=1800
# GROQ_TEXT_MAX_TOKENS_REPORT=2800
# LIQUID_ASK_MAX_TOKENS=1800
# See docs/groq-paid-testing.md

# Text narration / follow-up chat (AI insight + Liquid Scan Ask / Liquid Vault Q&A)
# Production: OpenAI → xAI → Groq → Gemini → OpenRouter. Free tier skips OpenAI/xAI.
# Verify Ask: GET /api/scan/liquid-chat (signed in) — see docs/liquid-scan-ask.md
TEXT_PROVIDER_ORDER=openrouter,groq,gemini,openai,xai
# Skip exhausted providers only (comma-separated). Keep groq/gemini for research + chat.
TEXT_SKIP_PROVIDERS=openai,xai
OPENAI_TEXT_MODEL=gpt-4o-mini
XAI_API_KEY=
XAI_TEXT_MODEL=grok-3-mini
OPENROUTER_TEXT_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Fallback OpenRouter models if primary 404s (comma-separated)
OPENROUTER_TEXT_MODEL_FALLBACKS=qwen/qwen3-coder:free,openrouter/free
# Liquid Ask chat + narration (best quality on Groq)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# Groq Compound — built-in web search for Ask, nightly market JSON, Master Catalog set insight
# Use compound-mini for lower spend when quality is enough: GROQ_COMPOUND_MODEL=groq/compound-mini
GROQ_COMPOUND_MODEL=groq/compound

# --- AI research budget (set insight, Liquid Ask, scan market JSON) ---
# Provider cooldown after 429 (minutes). Default 15.
# AI_RESEARCH_COOLDOWN_MIN=15
# Set insight cache (hours). Default 24 — refresh button bypasses AI skip.
# SET_INSIGHT_CACHE_HOURS=24
# Skip web-research when catalog already has strong TCGPlayer rollups (% priced + top lists).
# SET_INSIGHT_AI_SKIP_PRICED_PCT=80
# SET_INSIGHT_FORCE_AI=1
# SET_INSIGHT_GROQ_MAX_TOKENS=2000
# SET_INSIGHT_AI_ORDER=groq,gemini
# Liquid Ask web brief order (default: free Gemini search before Groq Compound)
LIQUID_ASK_WEB_BRIEF_ORDER=gemini,groq
# LIQUID_ASK_GROQ_BRIEF_MAX_TOKENS=2000
# Scan enrich: one LLM at a time until enough sold rows (not parallel Groq+Gemini)
MARKET_SCAN_AI_ORDER=gemini,groq

# Japanese artwork overlay manifest (optional path override)
# JAPANESE_ARTWORK_MANIFEST=src/data/pokedex/japanese-artwork-overlays.json
GEMINI_TEXT_MODEL=gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Dev server port
DEV_PORT=3002
# Next dev + ngrok for Clerk webhooks: npm run dev:tunnel

# Dev-only: allow calling /api/vision/extract without Clerk cookies when running local backend tests.
# Send header: x-pgt-dev-bypass: $DEV_VISION_BYPASS_TOKEN
DEV_VISION_BYPASS_TOKEN=

NEXT_PUBLIC_VISION_CLIENT_TIMEOUT_MS=300000
# Parallel vision requests during multi-image scans (1-6, default 3).
NEXT_PUBLIC_VISION_CONCURRENCY=3

# Optional PokeGrade Grading Engine API (live-scan HUD). Falls back to PGT vision+market when unset.
# POKEGRADE_API_URL=
# POKEGRADE_API_KEY=

# Optional second vision pass on weak rows only (name/set/number missing). Default on, max 4 per scan.
# Set to 0 to disable. Runs after bulk catalog+market finish (does not compete with enrich).
# Use max 2 on slower machines: NEXT_PUBLIC_SCAN_PRECISION_CROP_MAX=2
NEXT_PUBLIC_SCAN_PRECISION_CROP=1
NEXT_PUBLIC_SCAN_PRECISION_CROP_MAX=4

# Server-side vision fallback order (comma-separated).
# Free tier: groq + OpenRouter :free vision model below.
VISION_PROVIDER_ORDER=groq,openrouter
# Skip quota-burned providers. OpenAI/xAI also skipped when FREE_TIER_ONLY=1.
VISION_SKIP_PROVIDERS=gemini,openai,xai
# When OpenAI returns 429 quota errors, add: TEXT_SKIP_PROVIDERS=openai (Groq/Gemini/OpenRouter still run).
# Per-provider timeout in ms (default 90000, max 180000).
VISION_PROVIDER_TIMEOUT_MS=120000
# Max tokens for vision JSON (large binder pages; default 16384).
VISION_MAX_OUTPUT_TOKENS=16384
GROQ_VISION_MAX_OUTPUT_TOKENS=8192
# GEMINI_VISION_MAX_OUTPUT_TOKENS=16384
# OPENROUTER_VISION_MAX_OUTPUT_TOKENS=16384
# OPENAI_VISION_MAX_OUTPUT_TOKENS=16384
# Set to true to merge results from every provider that succeeds (slower).
VISION_MERGE_PROVIDERS=false

# Free market mode
# Required for vision: at least one of GROQ / GEMINI / OPENROUTER / OPENAI above.
# Free market data is always available from Pokemon TCG API embeds and allowed public snippets.
# Set this to "1" to skip every keyed marketplace adapter and only use free data.
MARKET_FREE_ONLY=0

# Liquid Ask research — Pro-only paid APIs (OpenRouter Sonar brief, eBay harvest, full enrich).
# Set to 0 until OpenRouter/eBay credits are loaded (Pro users then get free-tier research only).
# LIQUID_ASK_PRO_RESEARCH=1
# OPENROUTER_MARKET_MODEL=perplexity/sonar
# Optional free search fallback (1k credits/mo): TAVILY_API_KEY=

# Optional: bulk variant scans merged from PGT Market export.
# CATALOG_VARIANT_ARTWORK_MERGED_PATH=C:/Users/you/PGT Market/exports/catalog-variant-artwork.merged.json
CATALOG_VARIANT_ARTWORK_MERGED_PATH=

# Paid / keyed marketplace APIs (all optional)
# eBay Browse API: active listings via OAuth (category + condition filters, optional getItem enrich).
# Sold comps pipeline: Apify actor (recommended) → Marketplace Insights (when approved) → Finding → HTML.
# EBAY_DISABLE_FINDING=1 skips deprecated Finding API (Apify + HTML only).
# Finding sold comps — use Production App ID (same as EBAY_CLIENT_ID when unset). NOT EBAY_DEV_ID.
EBAY_FINDING_APP_ID=
EBAY_DISABLE_FINDING=0
EBAY_BROWSE_ENRICH_COUNT=4
EBAY_MARKETPLACE_INSIGHTS_ENABLED=0
EBAY_API_ENV=production
EBAY_USE_SANDBOX=0
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET=
# Apify eBay sold listings (uses APIFY_API_TOKEN from cert section below)
# EBAY_SOLD_APIFY=0
# APIFY_EBAY_SOLD_ACTOR=caffein.dev/ebay-sold-listings
# APIFY_EBAY_SOLD_COUNT=40
# APIFY_EBAY_SOLD_DAYS=90
# APIFY_EBAY_SOLD_TIMEOUT_SEC=90
# When Apify/direct HTML fail, use Bright Data Web Unlocker for completed listings (default on when configured)
# EBAY_SOLD_BRIGHTDATA=0

# PokeTrace — unified Pokemon prices (TCGPlayer, eBay, CardMarket; raw + graded tiers)
# Docs: https://poketrace.com/docs/cards — Free tier 250 req/day; Pro unlocks EU + graded + history
POKETRACE_API_KEY=
# POKETRACE_BASE_URL=https://api.poketrace.com/v1
# Prefer PokeTrace over Pokemon TCG API when both are configured (default on when key is set)
# MARKET_POKETRACE_PRIMARY=0
# Pro: daily /cards/{id}/prices/{tier}/history (set 0 to skip extra API calls on enrich)
# POKETRACE_HISTORY=0
# Scale only: WebSocket wss://api.poketrace.com/v1/ws — opt-in (REST works without this)
# POKETRACE_WS_ENABLED=1
# POKETRACE_WS_URL=wss://api.poketrace.com/v1/ws

# Cert registry + population (graded enrich + Liquid Ask)
# Chain: GemRate → PSA Public API → Apify PSA Pop → PSA cert page → DuckDuckGo
#
# GemRate (partner approval): https://www.gemrate.com/partner
GEMRATE_API_KEY=
GEMRATE_API_BASE_URL=https://api.gemrate.com
#
# PSA Public API (PSA account): https://www.psacard.com/publicapi
PSA_API_CLIENT_ID=
PSA_API_CLIENT_SECRET=
PSA_API_USERNAME=
PSA_API_PASSWORD=
PSA_API_TOKEN_URL=
PSA_API_BASE_URL=https://api.psacard.com/publicapi
# Optional: paste a short-lived bearer instead of OAuth (also passed to Apify actor)
# PSA_API_ACCESS_TOKEN=
#
# Apify PSA Pop Scraper fallback when GemRate/PSA API unavailable (~$5/1k results)
# https://apify.com/lulzasaur/psa-pop-scraper
APIFY_API_TOKEN=
# CERT_REGISTRY_APIFY=0
# APIFY_PSA_CACHE_HOURS=168
# APIFY_PSA_TIMEOUT_SEC=90
#
# Free: direct PSA cert HTML parse (set 0 to disable)
PSA_CERT_PAGE_SCRAPE=1

# Bright Data — Crawl API + Web Unlocker (PSA/BGS/CGC population harvest)
# API key: https://brightdata.com/cp/setting/users
# Crawl API: create a scraper for psacard.com / beckett.com / cgccards.com → copy dataset_id (gd_…)
# Web Unlocker: create zone → copy zone name (faster for single cert pages)
BRIGHTDATA_API_KEY=
BRIGHTDATA_CRAWL_DATASET_ID=
BRIGHTDATA_WEB_UNLOCKER_ZONE=
# BRIGHTDATA_CRAWL_OUTPUT_FORMAT=markdown
# BRIGHTDATA_POP_HARVEST_TIMEOUT_SEC=120
# BRIGHTDATA_UNLOCKER_TIMEOUT_SEC=90
# BRIGHTDATA_POP_HARVEST=0
# CERT_REGISTRY_BRIGHTDATA=0
# CATALOG_INGEST_GRADER_POP=0

# Card Ladder, ALT, and Goldin do not use server API keys in this repo (deep links only).
# PriceCharting API token (paid tier only) adds guide/reference rows.
PRICECHARTING_API_TOKEN=

# Server enrich cache
# MARKET_ENRICH_CACHE=0 disables cache entirely.
MARKET_ENRICH_CACHE_TTL_MS=1800000
MARKET_ENRICH_CACHE_MAX=250
# Drop observedAt on evidence rows older than this many days.
MARKET_MAX_EVIDENCE_AGE_DAYS=460
# Fetch dedicated PSA 10 / BGS BL / CGC Pristine eBay lanes when fewer than N session rows exist (default 1).
# MARKET_PREMIUM_LANE_MIN_ROWS=1
# Set to 1 to skip Gemini/snippet LLM when institutional memory already has 6+ sold comps (default: full research every scan).
# MARKET_SKIP_LLM_WHEN_MEMORY=0

# Pokémon TCG API v2 (https://dev.pokemontcg.io) — FREE dev key; required for master catalog TCGPlayer prices.
# After catalog:sync:pokemon run: npm run catalog:sync:pokemon-prices
# Without a key: catalog match still works via Supabase tcg_catalog_cards + slower/rate-limited live API.
# With a key: faster match, higher rate limits, reliable catalog sync. Add to Vercel Production env.
POKEMON_TCG_API_KEY=
# POKEMON_TCG_PRICE_DELAY_MS=220
# Catalog set insight without AI web research (TCGPlayer rollup only): CATALOG_SET_INSIGHT_DISABLE_GROQ=1

# Master catalog + nightly market memory (Vercel Cron — see vercel.json + docs/nightly-cron.md)
# Generate a long random string; Vercel sends Authorization: Bearer <CRON_SECRET>
# EST schedule (Vercel crons use UTC; EST = UTC−5, no DST adjustment in cron):
#   02:30 EST → nightly-platform · 02:50/03:10/03:30/03:50 EST → market-ingest
#   06:10 EST → nightly-final (catalog sync + full report)
# UTC: 07:30, 07:50, 08:10, 08:30, 08:50, 11:10
# Local: npm run platform:nightly · npm run market:ingest:set -- base1
CRON_SECRET=
#
# Nightly set ingest throughput (defaults tuned for Vercel 300s × 5 cron slots/night)
# MARKET_INGEST_MAX_CARDS=120
# MARKET_INGEST_CONCURRENCY=5
# MARKET_INGEST_TIME_BUDGET_MS=285000
# Nightly JSON comps: Groq Compound → Gemini Google Search → OpenRouter
# MARKET_NIGHTLY_AI_ORDER=groq,gemini,openrouter
# MARKET_NIGHTLY_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Skip live AI when comps ingested within N days (still refreshes API comps + prices)
# MARKET_NIGHTLY_MEMORY_FRESH_DAYS=10

# Companion sprites — Option B hosted CDN (optional; see docs/companion-sprites.md)
# NEXT_PUBLIC_PGT_SPRITE_CDN=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/pokemon-sprites
# NEXT_PUBLIC_COMPANION_SPRITES_HOSTED=1
