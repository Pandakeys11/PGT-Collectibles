# Auth: Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# ngrok (local Clerk webhooks): https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/scanner
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/scanner

# Database: Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Billing (Stripe) — standard Checkout only, NOT Stripe Connect
# Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: Developers → Webhooks → Add endpoint (NOT Connect webhooks)
#   URL: https://your-domain.com/api/billing/webhook
#   Event: checkout.session.completed
#   Docs: https://docs.stripe.com/webhooks (not /connect/webhooks)
# Local: stripe listen --forward-to localhost:3002/api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Public app URL for checkout redirects (defaults to VERCEL_URL or http://localhost:3002)
NEXT_PUBLIC_APP_URL=

# Vision providers (configure at least one; benchmark: npm run vision:benchmark)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# xAI / Grok (vision + optional paid tier; requires console credits)
XAI_API_KEY=
XAI_VISION_MODEL=grok-4-1-fast-non-reasoning
# XAI_BASE_URL=https://api.x.ai/v1

GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENAI_VISION_MODEL=gpt-4o-mini

# Free-tier-only mode: auto-skips OpenAI for vision + text (no paid API calls).
FREE_TIER_ONLY=1

# Text narration / follow-up chat (AI insight research brief)
# Free-tier chain: Groq → OpenRouter (:free) → Gemini. OpenAI skipped when FREE_TIER_ONLY=1.
TEXT_PROVIDER_ORDER=groq,openrouter,gemini
# Skip exhausted providers (comma-separated), e.g. TEXT_SKIP_PROVIDERS=groq,gemini
TEXT_SKIP_PROVIDERS=
OPENROUTER_TEXT_MODEL=meta-llama/llama-3.1-8b-instruct:free
GROQ_TEXT_MODEL=llama-3.1-8b-instant
GEMINI_TEXT_MODEL=gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Dev server port
DEV_PORT=3002
# Next dev + ngrok for Clerk webhooks: npm run dev:tunnel

NEXT_PUBLIC_VISION_CLIENT_TIMEOUT_MS=300000
# Parallel vision requests during multi-image scans (1-6, default 3).
NEXT_PUBLIC_VISION_CONCURRENCY=3

# Server-side vision fallback order (comma-separated).
# Free tier: groq + OpenRouter :free vision model below.
VISION_PROVIDER_ORDER=groq,openrouter
# Skip quota-burned providers. OpenAI/xAI also skipped when FREE_TIER_ONLY=1.
VISION_SKIP_PROVIDERS=gemini,openai,xai
# Per-provider timeout in ms (default 90000, max 180000).
VISION_PROVIDER_TIMEOUT_MS=120000
# Max tokens for vision JSON (large binder pages; default 16384).
VISION_MAX_OUTPUT_TOKENS=16384
GROQ_VISION_MAX_OUTPUT_TOKENS=8192
# GEMINI_VISION_MAX_OUTPUT_TOKENS=16384
# OPENROUTER_VISION_MAX_OUTPUT_TOKENS=16384
# OPENAI_VISION_MAX_OUTPUT_TOKENS=16384
# Set to true to merge results from every provider that succeeds (slower).
VISION_MERGE_PROVIDERS=false

# Free market mode
# Required for vision: at least one of GROQ / GEMINI / OPENROUTER / OPENAI above.
# Free market data is always available from Pokemon TCG API embeds and allowed public snippets.
# Set this to "1" to skip every keyed marketplace adapter and only use free data.
MARKET_FREE_ONLY=0

# Optional: bulk variant scans merged from PGT Market export.
# CATALOG_VARIANT_ARTWORK_MERGED_PATH=C:/Users/you/PGT Market/exports/catalog-variant-artwork.merged.json
CATALOG_VARIANT_ARTWORK_MERGED_PATH=

# Paid / keyed marketplace APIs (all optional)
# eBay Browse API: active listings via OAuth.
# Sold Finding API uses production svcs.ebay.com; set EBAY_FINDING_APP_ID when Browse is sandbox.
# EBAY_DISABLE_FINDING=1 forces HTML-only sold scrape.
EBAY_FINDING_APP_ID=
EBAY_DISABLE_FINDING=0
EBAY_API_ENV=production
EBAY_USE_SANDBOX=0
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET=

# Card Ladder, ALT, and Goldin do not use server API keys in this repo.
# PriceCharting API token (paid tier only) adds guide/reference rows.
PRICECHARTING_API_TOKEN=

# Server enrich cache
# MARKET_ENRICH_CACHE=0 disables cache entirely.
MARKET_ENRICH_CACHE_TTL_MS=1800000
MARKET_ENRICH_CACHE_MAX=250
# Drop observedAt on evidence rows older than this many days.
MARKET_MAX_EVIDENCE_AGE_DAYS=460

# Companion sprites — Option B hosted CDN (optional; see docs/companion-sprites.md)
# NEXT_PUBLIC_PGT_SPRITE_CDN=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/pokemon-sprites
# NEXT_PUBLIC_COMPANION_SPRITES_HOSTED=1
