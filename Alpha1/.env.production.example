# Safe to commit — copy to .env.production (gitignored) or paste into Vercel.
# Fill REPLACE values; import only the VERCEL_IMPORT block from .env.production.

NEXT_PUBLIC_APP_URL=https://YOUR_PRODUCTION_DOMAIN

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE
CLERK_SECRET_KEY=sk_live_REPLACE
CLERK_WEBHOOK_SECRET=whsec_REPLACE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/liquid-scan
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/liquid-scan
LEGACY_SCANNER_ENABLED=1

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE

STRIPE_SECRET_KEY=sk_live_REPLACE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

GROQ_API_KEY=REPLACE
GEMINI_API_KEY=REPLACE
OPENROUTER_API_KEY=REPLACE
OPENAI_API_KEY=REPLACE
XAI_API_KEY=REPLACE

FREE_TIER_ONLY=0
VISION_PROVIDER_ORDER=openrouter,gemini,groq,openai,xai
VISION_SKIP_PROVIDERS=
VISION_PROVIDER_TIMEOUT_MS=150000
VISION_MAX_OUTPUT_TOKENS=16384
GROQ_VISION_MAX_OUTPUT_TOKENS=8192
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_VISION_VERIFY_MODEL=gemini-2.5-flash
OPENAI_VISION_MODEL=gpt-4o-mini

TEXT_PROVIDER_ORDER=openrouter,groq,gemini,openai,xai
TEXT_SKIP_PROVIDERS=openai,xai
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_COMPOUND_MODEL=groq/compound
LIQUID_ASK_WEB_BRIEF_ORDER=gemini,groq
MARKET_SCAN_AI_ORDER=gemini,groq
MARKET_NIGHTLY_AI_ORDER=groq,gemini,openrouter

NEXT_PUBLIC_VISION_CLIENT_TIMEOUT_MS=300000
NEXT_PUBLIC_VISION_CONCURRENCY=3
NEXT_PUBLIC_SCAN_PRECISION_CROP=1
NEXT_PUBLIC_SCAN_PRECISION_CROP_MAX=4

MARKET_FREE_ONLY=0
MARKET_ENRICH_CACHE_TTL_MS=1800000
MARKET_ENRICH_CACHE_MAX=250
MARKET_MAX_EVIDENCE_AGE_DAYS=460

EBAY_API_ENV=production
EBAY_USE_SANDBOX=0
EBAY_CLIENT_ID=REPLACE
EBAY_CLIENT_SECRET=REPLACE
EBAY_FINDING_APP_ID=REPLACE
EBAY_DISABLE_FINDING=0

POKETRACE_API_KEY=REPLACE
POKEMON_TCG_API_KEY=REPLACE

# JustTCG — multi-franchise TCGPlayer prices (magic, yugioh, lorcana, onepiece)
JUSTTCG_API_KEY=REPLACE
JUSTTCG_BASE_URL=https://api.justtcg.com/v1
JUSTTCG_ENABLED=1
JUSTTCG_BATCH_SIZE=20
JUSTTCG_SYNC_DELAY_MS=450
JUSTTCG_SET_PAUSE_MS=1500

APIFY_API_TOKEN=REPLACE
PSA_API_KEY=REPLACE
PSA_CERT_PAGE_SCRAPE=1

BRIGHTDATA_API_KEY=REPLACE
BRIGHTDATA_WEB_UNLOCKER_ZONE=REPLACE
