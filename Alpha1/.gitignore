# Alpha1 — see also repo root .gitignore (PGT_Vision/.gitignore)

# Secrets & local env (templates .env.example / .env.production.example are tracked)
.env*.local
.env.production
.env.production.local

# Next.js
/.next/
/out/
/build

# Tooling
/node_modules
.vercel
.clerk/
*.tsbuildinfo
.eslintcache
.swc/
.turbo/

# Runtime caches (Bright Data, harvest checkpoints)
.cache/

# Local scratch — never commit captures (see _scratch/README.md)
_scratch/*
!_scratch/README.md
.tmp/
.tmp
.tmp-*
.tmp-*.*
tmp-*.log
tmp-*.out.log
tmp-*.err.log

# Generated
/reports/
/vendor/

# Debug logs (npm/yarn; dev scratch logs go under _scratch/)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem
/coverage

# Local dev test captures (not shipped assets)
/public/branding/binder-test-*

# Optional local catalog export drops (see CATALOG_*_PATH in .env.example)
/catalog-exports/
